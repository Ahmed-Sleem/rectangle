{
  "name": "@rectangle/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port ${PORT:-4173}",
    "start": "serve -s dist -l tcp://0.0.0.0:${PORT:-3000}",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src",
    "typecheck": "tsc -b --pretty false",
    "verify:deploy": "npm run typecheck && npm run lint && npm test && npm run build",
    "verify": "npm run verify:deploy",
    "verify:all": "npm run verify:deploy",
    "test:unit": "vitest run",
    "test:integration": "vitest run",
    "test:contract": "vitest run --passWithNoTests",
    "test:smoke": "npm run build"
  },
  "dependencies": {
    "@fontsource/inter": "^5.3.0",
    "i18next": "^26.3.6",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.11",
    "react-router-dom": "^7.18.1",
    "serve": "^14.2.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "typescript": "~5.9.3",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
