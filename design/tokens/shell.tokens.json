{
  "$description": "Rectangle centralized shell theme tokens — soft monochrome palette with semantic accent/status slots",
  "meta": {
    "source": "apps/web/src/shared/styles/tokens.css",
    "brand": "Rectangle",
    "version": "0.5.0"
  },
  "palette": {
    "void": "#18181b",
    "voidStrong": "#111113",
    "ink": "#202124",
    "inkStrong": "#17181a",
    "inkSoft": "#3f3f46",
    "muted": "#73737c",
    "faint": "#a1a1aa",
    "paper": "#f3f3f1",
    "paperElevated": "#f7f7f5",
    "paperSoft": "#ececea",
    "line": "#dededb",
    "lineStrong": "#c8c8c2",
    "accent": "#4f46e5",
    "accentSoft": "#eef0ff",
    "success": "#168a4a",
    "warning": "#b7791f",
    "danger": "#c2413a",
    "info": "#2563a9"
  },
  "semantic": {
    "chromeBg": "palette.void",
    "surfaceBg": "palette.paper",
    "surfaceBgHover": "palette.paperElevated",
    "surfaceBorder": "palette.ink",
    "textPrimary": "palette.inkStrong",
    "textSecondary": "palette.muted",
    "textMuted": "palette.faint",
    "cardBg": "palette.paperSoft",
    "cardBorder": "palette.line",
    "orbBg": "palette.inkStrong",
    "orbBgHover": "palette.voidStrong",
    "orbText": "palette.paperElevated",
    "accent": "palette.accent"
  },
  "font": {
    "family": "Inter, system-ui, sans-serif",
    "weights": [400, 500, 600, 700, 800, 900]
  },
  "size": {
    "menuWidthExpanded": 152,
    "menuWidthCollapsed": 40,
    "navItemHeight": 32,
    "navIcon": 18,
    "toggle": 28,
    "aiFab": 36,
    "aiPanelWidth": 360,
    "aiPanelWidthTablet": 320,
    "aiPanelWidthCollapsed": 0,
    "appGap": 8,
    "bodyPadding": 12
  },
  "radius": {
    "panel": 28,
    "navItem": 8,
    "card": 14,
    "pill": 999,
    "toggle": 999
  },
  "zIndex": {
    "menu": 1,
    "panel": 10,
    "edgeZone": 20,
    "toggle": 30
  }
}
